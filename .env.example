# =============================================================================
# Transformation Coach — Environment Variables
# Copy this file to .env and fill in all values
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- Telegram Bot ---
# Get BOT_TOKEN from: Telegram → @BotFather → /newbot
# Get CHAT_ID: message your bot, then visit:
#   https://api.telegram.org/bot<BOT_TOKEN>/getUpdates → look for chat.id
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# --- OpenClaw ---
# TELEGRAM_USER_ID is used by openclaw.json to restrict DMs to your account only.
# Set this to the same numeric value as TELEGRAM_CHAT_ID (your personal Telegram user ID).
# This is the allowFrom value in the OpenClaw gateway channel config.
TELEGRAM_USER_ID=REPLACE_ME

# --- App Config ---
TIMEZONE=Asia/Kolkata
DATABASE_URL=sqlite+aiosqlite:///data/transformation.db
LOG_LEVEL=INFO

# --- Google Sheets ---
# GOOGLE_SHEETS_ID: the long ID in your Google Sheet URL
#   https://docs.google.com/spreadsheets/d/<THIS_ID>/edit
# Steps: GCP Console → Enable Sheets API → Create Service Account → Download JSON
# Save as: credentials/google-service-account.json
# Share the Sheet with the service account email (Editor)
GOOGLE_SHEETS_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json

# --- Dashboard ---
DASHBOARD_PORT=8000
# Optional: bearer token to protect the API in production (leave empty for local dev)
DASHBOARD_API_TOKEN=
